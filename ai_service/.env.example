# ------------------------------------------------------------------
# Modèle de configuration du service IA (FastAPI).
# Copier en ".env" et renseigner les vraies clés.
# ATTENTION : dans un .env, on met UNIQUEMENT des paires CLE=valeur.
# Ne jamais coller de code Python ici (ex. FASHN_API_KEY = os.getenv(...)).
# ------------------------------------------------------------------

# Hugging Face (fournisseur gratuit CatVTON)
HF_TOKEN=
HF_CATVTON_SPACE=zhengchong/CatVTON

# Nombre d'étapes d'inférence (30 = bon compromis qualité / quota gratuit)
AI_NUM_STEPS=30

# Fournisseur : "catvton" (gratuit) ou "fashn" (API commerciale)
AI_TRYON_STRATEGY=catvton

# FASHN (fournisseur commercial, requis seulement si AI_TRYON_STRATEGY=fashn)
FASHN_API_KEY=

# Débogage uniquement : NE JAMAIS mettre "true" en production.
AI_DEBUG_FALLBACK=false
