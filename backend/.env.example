# ------------------------------------------------------------------
# Modèle de configuration backend TryOn.
# Copier ce fichier en ".env" et renseigner les vraies valeurs.
# NE JAMAIS committer le vrai ".env" (il est déjà dans .gitignore).
# ------------------------------------------------------------------

# Port du serveur backend
PORT=5000

# Base de données MySQL
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Clé secrète JWT — chaîne longue et aléatoire, à garder confidentielle.
# Générer par ex. avec :  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# SMTP (envoi des emails : OTP admin, réinitialisation mot de passe)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TryOn <no-reply@votredomaine.com>

# URL du frontend (redirections après authentification / OAuth)
FRONTEND_URL=http://localhost:3000

# URL publique du backend (utilisée par le callback Paydunya)
BACKEND_URL=http://localhost:5000

# Service IA d'essayage virtuel
AI_SERVICE_URL=http://localhost:8000
AI_TRYON_STRATEGY=catvton

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Paydunya — "test" (sandbox) ou "live" (vrai argent)
PAYDUNYA_MODE=test
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_PUBLIC_KEY=
