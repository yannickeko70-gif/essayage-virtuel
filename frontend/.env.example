# ------------------------------------------------------------------
# Modèle de configuration frontend (React / CRA).
# Copier en ".env" (dev) et/ou ".env.production" (mise en ligne).
# Les variables DOIVENT commencer par REACT_APP_ pour être lues par React.
# Après modification, relancer / rebuild : les valeurs sont figées au build.
# ------------------------------------------------------------------

# En développement :
REACT_APP_API_URL=http://localhost:5000/api/v1

# En production, mettre l'URL réelle du backend déployé, par exemple :
# REACT_APP_API_URL=https://api.votredomaine.com/api/v1
